{
  "name": "@dbsketch/core",
  "version": "0.0.0",
  "private": true,
  "description": "Compile DBML or SQL DDL into clean ASCII/Unicode ERD diagrams. Library entry point for dbsketch.",
  "keywords": [
    "erd",
    "entity-relationship-diagram",
    "database",
    "sql",
    "dbml",
    "diagram",
    "data-modeling",
    "schema",
    "ascii",
    "unicode",
    "documentation"
  ],
  "license": "MIT",
  "author": "Jacob Peters <jcbptrs@gmail.com>",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc --build"
  },
  "dependencies": {
    "@dbsketch/layout": "workspace:*",
    "@dbsketch/parser": "workspace:*",
    "@dbsketch/render": "workspace:*"
  }
}
