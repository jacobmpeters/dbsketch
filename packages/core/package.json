{
  "name": "@dbsketch/core",
  "version": "0.2.0",
  "description": "Compile DBML or SQL DDL into clean ASCII/Unicode ERD diagrams. Library entry point for dbsketch.",
  "keywords": [
    "erd",
    "entity-relationship-diagram",
    "database",
    "sql",
    "dbml",
    "diagram",
    "data-modeling",
    "schema",
    "ascii",
    "unicode",
    "documentation"
  ],
  "license": "MIT",
  "author": "Jacob Peters <jcbptrs@gmail.com>",
  "homepage": "https://github.com/jacobmpeters/dbsketch#readme",
  "bugs": "https://github.com/jacobmpeters/dbsketch/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jacobmpeters/dbsketch.git",
    "directory": "packages/core"
  },
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --build",
    "prepublishOnly": "tsc --build"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@dbsketch/layout": "workspace:*",
    "@dbsketch/parser": "workspace:*",
    "@dbsketch/render": "workspace:*"
  }
}
