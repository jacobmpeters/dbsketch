{
  "name": "@dbsketch/render",
  "version": "0.2.1",
  "description": "Text rendering for dbsketch ERD layouts; ASCII and Unicode box-drawing glyph tables.",
  "keywords": [
    "erd",
    "ascii",
    "ascii-art",
    "unicode",
    "box-drawing",
    "diagram",
    "render",
    "terminal"
  ],
  "license": "MIT",
  "author": "Jacob Peters <jcbptrs@gmail.com>",
  "homepage": "https://github.com/jacobmpeters/dbsketch#readme",
  "bugs": "https://github.com/jacobmpeters/dbsketch/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jacobmpeters/dbsketch.git",
    "directory": "packages/render"
  },
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --build",
    "prepublishOnly": "tsc --build"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@dbsketch/layout": "workspace:*",
    "@dbsketch/parser": "workspace:*"
  }
}
