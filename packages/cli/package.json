{
  "name": "@dbsketch/cli",
  "version": "0.2.1",
  "description": "Command-line tool to render DBML or SQL schemas as ASCII/Unicode ERD diagrams.",
  "keywords": [
    "erd",
    "entity-relationship-diagram",
    "database",
    "sql",
    "dbml",
    "diagram",
    "data-modeling",
    "schema",
    "ascii",
    "unicode",
    "documentation",
    "cli",
    "terminal"
  ],
  "license": "MIT",
  "author": "Jacob Peters <jcbptrs@gmail.com>",
  "homepage": "https://github.com/jacobmpeters/dbsketch#readme",
  "bugs": "https://github.com/jacobmpeters/dbsketch/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jacobmpeters/dbsketch.git",
    "directory": "packages/cli"
  },
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "bin": {
    "dbsketch": "./dist/bin.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --build",
    "bundle": "esbuild src/bin.ts --bundle --platform=node --target=node20 --format=cjs --minify --outfile=../../packages/pypi/dbsketch/_bin/cli.cjs",
    "dev": "tsx src/bin.ts",
    "prepublishOnly": "tsc --build"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@dbsketch/core": "workspace:*",
    "lz-string": "^1.5.0",
    "open": "^11.0.0"
  },
  "devDependencies": {
    "esbuild": "^0.28.0"
  }
}
