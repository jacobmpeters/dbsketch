{
  "name": "dbsketch",
  "private": true,
  "description": "Code-first ASCII/Unicode ERD diagrams from DBML or SQL. Monorepo for the @dbsketch/* packages.",
  "license": "MIT",
  "author": "Jacob Peters <jcbptrs@gmail.com>",
  "homepage": "https://github.com/jacobmpeters/dbsketch#readme",
  "bugs": "https://github.com/jacobmpeters/dbsketch/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jacobmpeters/dbsketch.git"
  },
  "type": "module",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc --build",
    "clean": "tsc --build --clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^20.16.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.0"
  }
}
